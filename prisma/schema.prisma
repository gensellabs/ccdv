generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model NewsPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String
  content     String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FeedbackSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  topic     FeedbackTopic
  subject   String
  message   String
  status    ModerationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

enum FeedbackTopic {
  LANDOWNERS
  INVESTORS
  GENERAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}
