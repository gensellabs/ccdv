# ─── DATABASE ────────────────────────────────────────────────────────────────
# Get a free PostgreSQL database from https://neon.tech (sign up, create project, copy connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Choose a strong password for the admin panel at /admin
ADMIN_PASSWORD="choose-a-strong-password-here"

# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# Get a free API key from https://resend.com (3,000 emails/month free)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# The email address that receives contact and feedback notifications
ADMIN_EMAIL="theoengels@me.com"

# The "from" address for outgoing emails (must be a verified domain in Resend)
# Until ccdv.co.za is verified in Resend, use: onboarding@resend.dev (Resend's test address)
FROM_EMAIL="onboarding@resend.dev"

# ─── SITE ────────────────────────────────────────────────────────────────────
# Your site URL (used in email links)
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
